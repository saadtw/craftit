{
  "name": "craftit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:editor": "npm run dev --prefix craftit-3d-editor",
    "dev:converter": "cross-env PYTHONUTF8=1 python -m uvicorn main:app --reload --port 8000 --app-dir converter-service",
    "dev:all": "concurrently --names \"NEXT,EDITOR,CONVERTER\" --prefix-colors \"cyan,magenta,yellow\" \"npm run dev\" \"npm run dev:editor\" \"npm run dev:converter\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup:supabase": "node scripts/setup-supabase.js"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.14.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "next": "^16.0.10",
    "next-auth": "^4.24.13",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.6.0",
    "shadcn-ui": "^0.9.5",
    "stripe": "^20.4.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "typewriter-effect": "^2.22.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "tailwindcss": "^4"
  }
}
